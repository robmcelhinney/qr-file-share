{
  "name": "@robmcelhinney/qr-file-share",
  "version": "0.1.10",
  "description": "Node.js http server allowing for file transfers over local area network made easier with QR code output on start.",
  "main": "server.js",
  "bin": "bin.js",
  "repository": "github:robmcelhinney/qr-file-share",
  "dependencies": {
    "express": "^5.2.1",
    "express-fileupload": "^1.5.1",
    "qrcode-terminal": "^0.12.0",
    "supertest": "^7.1.0",
    "yazl": "^3.3.1"
  },
  "scripts": {
    "test": "node --test",
    "test:browser": "playwright test",
    "start-server": "node bin.js",
    "start": "npm run build-client && node bin.js",
    "build-client": "npm --prefix client run build",
    "build:binaries": "npm run build-client && node scripts/build-binaries.js"
  },
  "files": [
    "client/dist",
    "bin.js",
    "server.js",
    "constants.js"
  ],
  "pkg": {
    "assets": [
      "client/dist/**"
    ]
  },
  "keywords": [
    "qr",
    "share",
    "WiFi",
    "terminal",
    "file",
    "share"
  ],
  "devDependencies": {
    "@playwright/test": "^1.58.2",
    "pkg": "^5.8.1"
  }
}
